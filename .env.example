# ========================================
# TuMesaHoy - Variables de Entorno
# ========================================
# Copia este archivo a .env y completa con tus credenciales reales
# NO commitees el archivo .env al repositorio
# ========================================

# ------------------
# SUPABASE
# ------------------
# Obtener en: Supabase Dashboard > Settings > API
VITE_SUPABASE_URL=https://tu-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=tu_anon_key_aqui

# ------------------
# MERCADO PAGO
# ------------------
# Obtener en: https://www.mercadopago.com.ar/developers
# Ir a: Tus aplicaciones > [Tu App] > Credenciales
VITE_MP_PUBLIC_KEY=tu_public_key_aqui

# Para la feature de seña online (Marketplace/OAuth)
# VITE_MP_APP_ID = el "Client ID" de tu app en MP (público, va en el frontend)
VITE_MP_APP_ID=tu_app_id_aqui

# ------------------
# EDGE FUNCTIONS Y VERCEL (NO agregar en .env, configurar en los dashboards)
# ------------------
# Supabase Dashboard > Edge Functions > Secrets:
#   MP_ACCESS_TOKEN, SUPABASE_SERVICE_ROLE_KEY, SUPABASE_ANON_KEY, FRONTEND_URL
#
# Vercel Dashboard > Settings > Environment Variables:
#   MP_APP_ID=tu_app_id (mismo que VITE_MP_APP_ID)
#   MP_APP_SECRET=tu_client_secret (SECRETO, nunca en el frontend)
#   SUPABASE_SERVICE_ROLE_KEY=tu_service_role_key

# ------------------
# EDGE FUNCTIONS (Configurar en Supabase Dashboard)
# ------------------
# NO agregar estas aquí, se configuran en Supabase Dashboard > Edge Functions > Secrets
# MP_ACCESS_TOKEN=tu_access_token_aqui
# SUPABASE_SERVICE_ROLE_KEY=tu_service_role_key_aqui
# SUPABASE_ANON_KEY=tu_anon_key_aqui (mismo que VITE_SUPABASE_ANON_KEY)

# ------------------
# SUPERADMIN
# ------------------
# Email del superadmin de la plataforma (accede a /super-admin)
# CRÍTICO: Mantener en secreto, no commitear el valor real
VITE_SUPERADMIN_EMAIL=tu_email_superadmin@ejemplo.com

# ------------------
# SEGURIDAD - CORS (Opcional)
# ------------------
# URL del frontend en producción para restringir CORS
# Si no se configura, usará localhost en desarrollo
# FRONTEND_URL=https://tumesahoy.com

# ------------------
# SEGURIDAD - WEBHOOK MERCADO PAGO (CRÍTICO)
# ------------------
# Secret para validar webhooks de Mercado Pago
# Obtener en: Mercado Pago Dashboard > Webhooks > [Tu webhook] > Secret
# IMPORTANTE: Esto es CRÍTICO para prevenir webhooks falsos
# MP_WEBHOOK_SECRET=tu_webhook_secret_aqui

# ------------------
# EMAIL (Resend) — Configurar en Supabase Dashboard > Edge Functions > Secrets
# ------------------
# Obtener API key en: https://resend.com/api-keys
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# FROM_EMAIL=TuMesaHoy <reservas@tumesahoy.com>
